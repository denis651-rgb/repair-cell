{
  "name": "cell-repair-desktop-app",
  "version": "1.0.0",
  "private": true,
  "author": "Denis RGB",
  "description": "Sistema de escritorio offline para taller de reparacion de celulares",
  "main": "electron/main.js",
  "scripts": {
    "clean:dist": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\clean-dist.ps1",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "backend:package": "mvn -q -DskipTests package -f backend/pom.xml",
    "electron:dev": "electron .",
    "desktop:dev": "concurrently \"npm run frontend:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run clean:dist && npm run backend:package && npm run frontend:build && electron-builder",
    "dist:win": "npm run dist -- --win nsis"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.tallercelular.desktop",
    "productName": "Taller Celular",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/target/repair-backend-1.0.0.jar",
        "to": "backend/repair-backend.jar"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
